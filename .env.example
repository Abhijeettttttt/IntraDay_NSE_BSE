# Angel One SmartAPI credentials — copy this file to ".env" and fill in.
# NEVER commit the real .env file.

ANGELONE_API_KEY=your_api_key_here
ANGELONE_CLIENT_CODE=your_client_code_here
ANGELONE_MPIN=your_mpin_here
ANGELONE_TOTP_SECRET=your_base32_totp_secret_here

# Data provider to use: "mock" (default, no credentials needed) or "angelone"
DATA_PROVIDER=mock
